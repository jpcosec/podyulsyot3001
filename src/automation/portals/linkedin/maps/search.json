{
  "meta": {
    "source": "linkedin",
    "flow": "search",
    "version": "v1",
    "status": "draft"
  },
  "states": {
    "search_results": {
      "id": "search_results",
      "description": "LinkedIn job search results page with visible listing cards.",
      "presence_predicate": {
        "required_elements": [
          { "css": ".jobs-search-results-list" }
        ],
        "logical_op": "AND"
      },
      "components": {
        "results_list": { "css": ".jobs-search-results-list" }
      }
    },
    "discovery_complete": {
      "id": "discovery_complete",
      "description": "Discovery mission completed after collecting visible listing content.",
      "presence_predicate": {
        "required_elements": [
          { "css": ".jobs-search-results-list" }
        ],
        "logical_op": "AND"
      },
      "components": {}
    }
  },
  "edges": [
    {
      "from_state": "search_results",
      "to_state": "discovery_complete",
      "mission_id": "discovery",
      "intent": "extract",
      "target": "results_list",
      "extract": {
        "jobs_text": ".jobs-search-results-list"
      }
    }
  ],
  "success_states": ["discovery_complete"],
  "failure_states": []
}
