{
  "portal_name": "linkedin",
  "base_url": "https://www.linkedin.com",
  "states": {
    "job_details": {
      "id": "job_details",
      "description": "The main job description page with apply buttons",
      "presence_predicate": {
        "required_elements": [
          { "css": ".jobs-description", "text": "Job description" }
        ]
      },
      "components": {
        "easy_apply_button": { "css": "button.jobs-apply-button", "text": "Easy Apply" },
        "external_apply_button": { "css": "a.jobs-apply-button", "text": "Apply" }
      }
    },
    "easy_apply_modal_contact": {
      "id": "easy_apply_modal_contact",
      "description": "First step of Easy Apply modal: Contact info",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-test-modal-id='apply-modal']", "text": "Contact info" }
        ]
      },
      "components": {
        "first_name": { "css": "input[name='firstName']" },
        "last_name": { "css": "input[name='lastName']" },
        "next_button": { "css": "button[aria-label='Continue to next step']", "text": "Next" }
      }
    },
    "easy_apply_modal_resume": {
      "id": "easy_apply_modal_resume",
      "description": "Resume upload step of Easy Apply modal",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-test-modal-id='apply-modal']", "text": "Resume" }
        ]
      },
      "components": {
        "upload_input": { "css": "input[type='file'][accept*='pdf']" },
        "next_button": { "css": "button[aria-label='Continue to next step']", "text": "Next" }
      }
    },
    "easy_apply_modal_review": {
      "id": "easy_apply_modal_review",
      "description": "Final review step before submission",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-test-modal-id='apply-modal']", "text": "Review your application" }
        ]
      },
      "components": {
        "submit_button": { "css": "button[aria-label='Submit application']", "text": "Submit application" }
      }
    },
    "apply_success": {
      "id": "apply_success",
      "description": "Post-apply success state",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-test-modal-id='post-apply-modal']", "text": "Application sent" }
        ]
      }
    }
  },
  "tasks": {
    "submit_easy_apply": {
      "id": "submit_easy_apply",
      "goal": "submit_job_application",
      "entry_state": "job_details",
      "success_states": ["apply_success"],
      "failure_states": [],
      "blocker_recovery": [
        {
          "trigger_predicate": { "required_elements": [{ "css": ".artdeco-toast-item--error" }] },
          "recovery_actions": [],
          "resume_strategy": "ABORT"
        }
      ]
    }
  },
  "paths": {
    "standard_easy_apply": {
      "id": "standard_easy_apply",
      "task_id": "submit_easy_apply",
      "steps": [
        {
          "step_index": 1,
          "name": "open_modal",
          "description": "Click the Easy Apply button",
          "state_id": "job_details",
          "observe": { "required_elements": [{ "css": "button.jobs-apply-button" }] },
          "actions": [
            { "intent": "click", "target": { "css": "button.jobs-apply-button", "text": "Easy Apply" } }
          ]
        },
        {
          "step_index": 2,
          "name": "fill_contact",
          "description": "Fill basic info and continue",
          "state_id": "easy_apply_modal_contact",
          "observe": { "required_elements": [{ "css": "input[name='firstName']" }] },
          "actions": [
            { "intent": "fill", "target": { "css": "input[name='firstName']" }, "value": "{{profile.first_name}}" },
            { "intent": "click", "target": { "css": "button[aria-label='Continue to next step']" } }
          ]
        },
        {
          "step_index": 3,
          "name": "upload_resume",
          "description": "Upload the CV",
          "state_id": "easy_apply_modal_resume",
          "observe": { "required_elements": [{ "css": "input[type='file']" }] },
          "actions": [
            { "intent": "upload", "target": { "css": "input[type='file']" }, "value": "{{cv_path}}" },
            { "intent": "click", "target": { "css": "button[aria-label='Continue to next step']" } }
          ]
        },
        {
          "step_index": 4,
          "name": "submit",
          "description": "Final submission",
          "state_id": "easy_apply_modal_review",
          "observe": { "required_elements": [{ "css": "button[aria-label='Submit application']" }] },
          "actions": [
            { "intent": "click", "target": { "css": "button[aria-label='Submit application']" } }
          ],
          "dry_run_stop": true
        }
      ]
    }
  }
}
