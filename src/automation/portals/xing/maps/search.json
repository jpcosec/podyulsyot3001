{
  "portal_name": "xing",
  "base_url": "https://www.xing.com/jobs/search",
  "states": {
    "search_landing": {
      "id": "search_landing",
      "description": "XING job search home",
      "presence_predicate": {
        "required_elements": [
          { "css": "input[name='keywords']", "text": "Stichwort" }
        ]
      },
      "components": {
        "keyword_input": { "css": "input[name='keywords']" },
        "location_input": { "css": "input[name='location']" },
        "search_button": { "css": "button[type='submit']" }
      }
    },
    "search_results": {
      "id": "search_results",
      "description": "XING search results list",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-testid='search-results-list']" }
        ]
      }
    }
  },
  "tasks": {
    "perform_search": {
      "id": "perform_search",
      "goal": "execute_search_query",
      "entry_state": "search_landing",
      "success_states": ["search_results"],
      "failure_states": [],
      "success_criteria": { "text_match": "Ergebnisse" }
    }
  },
  "paths": {
    "standard_search": {
      "id": "standard_search",
      "task_id": "perform_search",
      "steps": [
        {
          "step_index": 1,
          "name": "enter_criteria",
          "description": "Enter search keywords and location",
          "state_id": "search_landing",
          "observe": { "required_elements": [{ "css": "input[name='keywords']" }] },
          "actions": [
            { "intent": "fill", "target": { "css": "input[name='keywords']" }, "value": "{{keywords}}" },
            { "intent": "fill", "target": { "css": "input[name='location']" }, "value": "{{location}}" }
          ]
        },
        {
          "step_index": 2,
          "name": "click_search",
          "description": "Click search button",
          "state_id": "search_landing",
          "observe": { "required_elements": [{ "css": "button[type='submit']" }] },
          "actions": [
            { "intent": "click", "target": { "css": "button[type='submit']" } }
          ]
        }
      ]
    }
  }
}
