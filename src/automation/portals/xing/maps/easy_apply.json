{
  "portal_name": "xing",
  "base_url": "https://www.xing.com",
  "states": {
    "job_details": {
      "id": "job_details",
      "description": "XING job listing page with internal apply",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-testid='apply-button']" }
        ]
      },
      "components": {
        "apply_button": { "css": "[data-testid='apply-button']" }
      }
    },
    "external_apply": {
      "id": "external_apply",
      "description": "XING job that routes to an external ATS via employer website button",
      "presence_predicate": {
        "required_elements": [
          { "css": ".apply-button__Apply" }
        ]
      },
      "components": {
        "employer_website_button": { "css": ".apply-button__Apply" }
      }
    },
    "easy_apply_modal": {
      "id": "easy_apply_modal",
      "description": "XING Easy Apply modal",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-testid='apply-modal']" }
        ]
      },
      "components": {
        "first_name": { "css": "input[name='firstName']" },
        "last_name": { "css": "input[name='lastName']" },
        "email": { "css": "input[type='email']" },
        "phone": { "css": "input[name='phone']" },
        "cv_upload": { "css": "input[type='file']" },
        "submit_button": { "css": "[data-testid='submit-button']" }
      }
    },
    "apply_success": {
      "id": "apply_success",
      "description": "XING success page",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-testid='application-success']" }
        ]
      }
    }
  },
  "tasks": {
    "submit_easy_apply": {
      "id": "submit_easy_apply",
      "goal": "submit_job_application",
      "entry_state": "job_details",
      "success_states": ["apply_success"],
      "failure_states": ["external_apply"],
      "success_criteria": { "text_match": "Bewerbung" }
    }
  },
  "paths": {
    "standard_easy_apply": {
      "id": "standard_easy_apply",
      "task_id": "submit_easy_apply",
      "steps": [
        {
          "step_index": 1,
          "name": "open_modal",
          "description": "Open apply modal or detect external apply route",
          "state_id": "job_details",
          "observe": {
            "logical_op": "OR",
            "required_elements": [
              { "css": "[data-testid='apply-button']" },
              { "css": ".apply-button__Apply" }
            ]
          },
          "actions": [
            { "intent": "click", "target": { "css": "[data-testid='apply-button']" }, "fallback": { "intent": "click", "target": { "css": ".apply-button__Apply" } } }
          ]
        },
        {
          "step_index": 2,
          "name": "fill_contact",
          "description": "Fill contact info",
          "state_id": "easy_apply_modal",
          "observe": { "required_elements": [{ "css": "input[name='firstName']" }] },
          "actions": [
            { "intent": "fill", "target": { "css": "input[name='firstName']" }, "value": "{{profile.first_name}}" },
            { "intent": "fill", "target": { "css": "input[name='lastName']" }, "value": "{{profile.last_name}}" },
            { "intent": "fill", "target": { "css": "input[type='email']" }, "value": "{{profile.email}}" },
            { "intent": "fill", "target": { "css": "input[name='phone']" }, "value": "{{profile.phone}}", "optional": true }
          ]
        },
        {
          "step_index": 3,
          "name": "upload_cv",
          "description": "Upload CV",
          "state_id": "easy_apply_modal",
          "observe": { "required_elements": [{ "css": "input[type='file']" }] },
          "actions": [
            { "intent": "upload", "target": { "css": "input[type='file']" }, "value": "{{cv_path}}" }
          ]
        },
        {
          "step_index": 4,
          "name": "submit",
          "description": "Submit application",
          "state_id": "easy_apply_modal",
          "observe": { "required_elements": [{ "css": "[data-testid='submit-button']" }] },
          "actions": [
            { "intent": "click", "target": { "css": "[data-testid='submit-button']" } }
          ],
          "dry_run_stop": true
        }
      ]
    }
  }
}
