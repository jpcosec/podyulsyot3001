{
  "meta": {
    "source": "stepstone",
    "flow": "easy_apply",
    "version": "v1",
    "status": "verified"
  },
  "states": {
    "job_details": {
      "id": "job_details",
      "description": "StepStone job listing page with internal apply",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-at='apply-button']" }
        ],
        "logical_op": "AND"
      },
      "components": {
        "apply_button": { "css": "[data-at='apply-button']", "text": "Apply Now" },
        "employer_website_button": { "text": "Ich bin interessiert" }
      }
    },
    "external_apply": {
      "id": "external_apply",
      "description": "StepStone job that routes to external ATS via employer website button",
      "presence_predicate": {
        "required_elements": [
          { "text": "Ich bin interessiert" }
        ],
        "logical_op": "AND"
      },
      "components": {
        "employer_website_button": { "text": "Ich bin interessiert" }
      }
    },
    "easy_apply_modal": {
      "id": "easy_apply_modal",
      "description": "StepStone Easy Apply modal",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-at='apply-modal']" }
        ],
        "logical_op": "AND"
      },
      "components": {
        "first_name": { "css": "input[name='firstName']" },
        "last_name": { "css": "input[name='lastName']" },
        "email": { "css": "input[type='email']" },
        "phone": { "css": "input[name='phone']" },
        "cv_upload": { "css": "input[type='file']" },
        "submit_button": { "css": "[data-at='submit-button']" }
      }
    },
    "apply_success": {
      "id": "apply_success",
      "description": "StepStone success page",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-at='application-success']" }
        ],
        "logical_op": "AND"
      },
      "components": {}
    }
  },
  "edges": [
    {
      "from_state": "job_details",
      "to_state": "easy_apply_modal",
      "intent": "click",
      "target": "apply_button"
    },
    {
      "from_state": "job_details",
      "to_state": "external_apply",
      "intent": "click",
      "target": "employer_website_button"
    },
    {
      "from_state": "easy_apply_modal",
      "to_state": "easy_apply_modal",
      "intent": "fill",
      "target": "first_name",
      "value": "{{profile.first_name}}"
    },
    {
      "from_state": "easy_apply_modal",
      "to_state": "easy_apply_modal",
      "intent": "fill",
      "target": "last_name",
      "value": "{{profile.last_name}}"
    },
    {
      "from_state": "easy_apply_modal",
      "to_state": "easy_apply_modal",
      "intent": "fill",
      "target": "email",
      "value": "{{profile.email}}"
    },
    {
      "from_state": "easy_apply_modal",
      "to_state": "easy_apply_modal",
      "intent": "fill",
      "target": "phone",
      "value": "{{profile.phone}}"
    },
    {
      "from_state": "easy_apply_modal",
      "to_state": "easy_apply_modal",
      "intent": "upload",
      "target": "cv_upload",
      "value": "{{cv_path}}"
    },
    {
      "from_state": "easy_apply_modal",
      "to_state": "apply_success",
      "intent": "click",
      "target": "submit_button"
    }
  ],
  "success_states": ["apply_success"],
  "failure_states": ["external_apply"]
}
