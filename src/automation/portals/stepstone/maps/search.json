{
  "portal_name": "stepstone",
  "base_url": "https://www.stepstone.de",
  "states": {
    "search_landing": {
      "id": "search_landing",
      "description": "StepStone home page",
      "presence_predicate": {
        "required_elements": [
          { "css": "input[id='job-search-bar-keywords-input']", "text": "Was" }
        ]
      },
      "components": {
        "keyword_input": { "css": "input[id='job-search-bar-keywords-input']" },
        "location_input": { "css": "input[id='job-search-bar-location-input']" },
        "search_button": { "css": "button[data-testid='job-search-bar-submit-button']" }
      }
    },
    "search_results": {
      "id": "search_results",
      "description": "StepStone search results",
      "presence_predicate": {
        "required_elements": [
          { "css": "[data-testid='results-list']" }
        ]
      }
    }
  },
  "tasks": {
    "perform_search": {
      "id": "perform_search",
      "goal": "execute_search_query",
      "entry_state": "search_landing",
      "success_states": ["search_results"],
      "failure_states": [],
      "success_criteria": { "text_match": "Jobs" }
    }
  },
  "paths": {
    "standard_search": {
      "id": "standard_search",
      "task_id": "perform_search",
      "steps": [
        {
          "step_index": 1,
          "name": "enter_criteria",
          "description": "Enter keywords and location",
          "state_id": "search_landing",
          "observe": { "required_elements": [{ "css": "input[id='job-search-bar-keywords-input']" }] },
          "actions": [
            { "intent": "fill", "target": { "css": "input[id='job-search-bar-keywords-input']" }, "value": "{{keywords}}" },
            { "intent": "fill", "target": { "css": "input[id='job-search-bar-location-input']" }, "value": "{{location}}" }
          ]
        },
        {
          "step_index": 2,
          "name": "click_search",
          "description": "Click search button",
          "state_id": "search_landing",
          "observe": { "required_elements": [{ "css": "button[data-testid='job-search-bar-submit-button']" }] },
          "actions": [
            { "intent": "click", "target": { "css": "button[data-testid='job-search-bar-submit-button']" } }
          ]
        }
      ]
    }
  }
}
