% Definition of the class moderncv with some parameters. Font size 11pt, paper size A4, font sans
\documentclass[11pt, a4paper, sans]{moderncv}

% Includes all the necessary packages from packages.tex
\input{Einstellungen/packages}

% Defines commands and parameters for modifying the included packages
\input{Einstellungen/commands}

% Beginning of document
\begin{document}
    \pagestyle{empty}

    %Creates the CV title with Name and photo
    \myCVtitle{ {{ personal.first_name }} }{ {{ personal.last_name }} }{Abbildungen/profile.jpg}

    %Reduce the vertical space by 10 points
    \vspace*{-10pt}

    %Personal information section
    \section{Información Personal}
        \cvline{Dirección}{ {{ personal.address }} \newline {% if personal.postal_code %}{{ personal.postal_code }}, {% endif %}{{ personal.city }} }
        \cvline{Teléfono}{ {{ personal.phone }} }
        \cvline{E-mail}{\href{mailto: {{ personal.email }} }{ {{ personal.email }} }}
        \cvline{Nacionalidad}{ {{ personal.nationality }} }
        \cvline{Fecha de nacimiento}{ {{ personal.birthday|replace('-', '.') }} }
        \cvline{Permiso de trabajo}{ {{ personal.work_permission }} }

    \section{Educación}
    {% for edu in education %}
        \cventry{ {{ edu.start_date|replace('-', '/') }} - {{ edu.end_date|replace('-', '/') }} }
                { {{ edu.field }} }
                { {{ edu.institution }} }
                { {{ edu.location }} }
                { {{ edu.level }} }
                {
        {% if edu.focus %}
                \begin{itemize}
            {% for item in edu.focus %}
                    \item {{ item }}
            {% endfor %}
                \end{itemize}
        {% endif %}
                }
    {% endfor %}

    \section{Experiencia Profesional}
    {% for job in experience %}

        \cventry{ {{ job.start_date|replace('-', '/') }} - {{ job.end_date|replace('-', '/') }} }
                { {{ job.title }} }
                { {{ job.company }} }
                { {{ job.location }} }
                {}
                {
        {% if job.description %}
                \begin{itemize}
            {% for desc in job.description %}
                    \item {{ desc }}
            {% endfor %}
                \end{itemize}
        {% endif %}
                }

    {% if not loop.last %}
        \vspace{6pt}
    {% endif %}
    {% endfor %}

    {% if projects %}
    \section{Proyectos Destacados}
    {% for proj in projects %}

        \cventry{}
                { {{ proj.name }} }
                { {{ proj.role }} }
                {}
                {}
                {
        {% if proj.summary %}
                {{ proj.summary }}
        {% endif %}
        {% if proj.highlights %}
                \begin{itemize}
            {% for item in proj.highlights %}
                    \item {{ item }}
            {% endfor %}
                \end{itemize}
        {% endif %}
        {% if proj.stack %}
                \textit{Stack:} {{ proj.stack|join(', ') }}
        {% endif %}
                }

    {% endfor %}
    {% endif %}

    \section{Publicaciones}
    {% for pub in publications|groupby('year')|reverse %}
        \cvline{ {{ pub.grouper }} }{
                \begin{itemize}
        {% for publication in pub.list %}
                    \item {{ publication.authors|join(', ') }}: \textit{``{{ publication.title }}''} {{ publication.venue }}{% if publication.url %} \url{ {{ publication.url }} }{% endif %}
            {% if publication.contribution %}
                    \begin{itemize}
                        \item \textit{Contribución:} {{ publication.contribution }}
                    \end{itemize}
            {% endif %}
        {% endfor %}
                \end{itemize}
                }
    {% endfor %}

    \section{Idiomas}
    {% for lang in skills.languages %}
            \cvlanguage{ {{ lang.name }} }{ {{ lang.level }} }{}
    {% endfor %}

    \section{Competencias Técnicas}
        \noindent\textbf{Machine Learning}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        scikit-learn, TensorFlow/Keras, PyTorch, LLM-Prompting, Evaluación/Model Cards, Métodos Bayesianos
        \vspace{8pt}

        \noindent\textbf{Ingeniería de Datos y Big Data}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        ELT/ETL-Design, Azure Data Factory, Databricks, Spark, Delta Lake, Data Contracts
        \vspace{8pt}

        \noindent\textbf{Backend}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        FastAPI/Flask, API-Design, Kafka, PostgreSQL, MongoDB, Neo4j, Redis, gRPC/REST, Testing (pytest), Observability
        \vspace{8pt}

        \noindent\textbf{Visión por Computadora y Procesamiento de Imágenes}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Deep Learning (CNNs, Transfer Learning), CV Clásica, Preprocesamiento, OpenCV, torchvision
        \vspace{8pt}

        \noindent\textbf{Cloud y Orquestación}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Apache Airflow, Prefect, Docker/Containerización, CI/CD (Git, Pipelines)
        \vspace{8pt}

        \noindent\textbf{BI y Analytics}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Power BI (DAX, RLS), Star Schema Modelado, Diseño de Dashboard y Governance
        \vspace{8pt}

        \noindent\textbf{Full-Stack y Frontend}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Django (MVC, ORM, Admin), HTML/CSS/JavaScript, CRUD APIs, Templates, Godot (GDScript)
        \vspace{8pt}

        \noindent\textbf{Ingeniería Eléctrica y Sistemas Embebidos}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        C (Embebido/Fundamentos de Programación), Verilog (RTL-Design), Procesamiento de Señales, Circuitos Analógicos/Digitales, FPGA-Design

    % Signature
    \sign{ {{ personal.full_name }} }{ {{ personal.city }} }{Abbildungen/profile.jpg}

\end{document}
