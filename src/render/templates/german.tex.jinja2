% Definition of the class moderncv with some parameters. Font size 11pt, paper size A4, font sans
\documentclass[11pt, a4paper, sans]{moderncv}

% Includes all the necessary packages from packages.tex
\input{Einstellungen/packages}

% Defines commands and parameters for modifying the included packages
\input{Einstellungen/commands}

% Beginning of document
\begin{document}
    \pagestyle{empty}

    %Creates the CV title with Name and photo
    \myCVtitle{ {{ personal.first_name }} }{ {{ personal.last_name }} }{Abbildungen/profile.jpg}

    %Reduce the vertical space by 10 points
    \vspace*{-10pt}

    %Personal information section
    \section{Angaben zur Person}
        \cvline{Adresse}{ {{ personal.address }} \newline {% if personal.postal_code %}{{ personal.postal_code }}, {% endif %}{{ personal.city }} }
        \cvline{Telefon}{ {{ personal.phone }} }
        \cvline{E-mail}{\href{mailto: {{ personal.email }} }{ {{ personal.email }} }}
        \cvline{Staatsangehörigkeit}{ {{ personal.nationality }} }
        \cvline{Geburtstag}{ {{ personal.birthday|replace('-', '.') }} }
        \cvline{Arbeitserlaubnis}{ {{ personal.work_permission }} }

    \section{Ausbildung}
    {% for edu in education %}
        \cventry{ {{ edu.start_date|replace('-', '/') }} - {{ edu.end_date|replace('-', '/') }} }
                { {{ edu.field }} }
                { {{ edu.institution }} }
                { {{ edu.location }} }
                { {{ edu.level }} }
                {
        {% if edu.focus %}
                \begin{itemize}
            {% for item in edu.focus %}
                    \item {{ item }}
            {% endfor %}
                \end{itemize}
        {% endif %}
                }
    {% endfor %}

    \section{Berufserfahrung}
    {% for job in experience %}

        \cventry{ {{ job.start_date|replace('-', '/') }} - {{ job.end_date|replace('-', '/') }} }
                { {{ job.title }} }
                { {{ job.company }} }
                { {{ job.location }} }
                {}
                {
        {% if job.description %}
                \begin{itemize}
            {% for desc in job.description %}
                    \item {{ desc }}
            {% endfor %}
                \end{itemize}
        {% endif %}
                }

    {% if not loop.last %}
        \vspace{6pt}
    {% endif %}
    {% endfor %}

    {% if projects %}
    \section{Bemerkenswerte Projekte}
    {% for proj in projects %}

        \cventry{}
                { {{ proj.name }} }
                { {{ proj.role }} }
                {}
                {}
                {
        {% if proj.summary %}
                {{ proj.summary }}
        {% endif %}
        {% if proj.highlights %}
                \begin{itemize}
            {% for item in proj.highlights %}
                    \item {{ item }}
            {% endfor %}
                \end{itemize}
        {% endif %}
        {% if proj.stack %}
                \textit{Stack:} {{ proj.stack|join(', ') }}
        {% endif %}
                }

    {% endfor %}
    {% endif %}

    \section{Publikationen}
    {% for pub in publications|groupby('year')|reverse %}
        \cvline{ {{ pub.grouper }} }{
                \begin{itemize}
        {% for publication in pub.list %}
                    \item {{ publication.authors|join(', ') }}: \textit{``{{ publication.title }}''} {{ publication.venue }}{% if publication.url %} \url{ {{ publication.url }} }{% endif %}
            {% if publication.contribution %}
                    \begin{itemize}
                        \item \textit{Beitrag:} {{ publication.contribution }}
                    \end{itemize}
            {% endif %}
        {% endfor %}
                \end{itemize}
                }
    {% endfor %}

    \section{Sprachen}
    {% for lang in skills.languages %}
            \cvlanguage{ {{ lang.name }} }{ {{ lang.level }} }{}
    {% endfor %}

    \section{Fachliche Kompetenzen}
    {% for category, items in skills.technical.items() %}
        \noindent\textbf{ {{ category|replace('_', ' ')|title }} }
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        {% if items is string %}{{ items }}{% else %}{{ items|join(', ') }}{% endif %}
        \vspace{8pt}

    {% endfor %}

    % Signature
    \sign{ {{ personal.full_name }} }{ {{ personal.city }} }{Abbildungen/profile.jpg}

\end{document}
