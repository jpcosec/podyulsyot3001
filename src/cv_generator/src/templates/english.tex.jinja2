% Definition of the class moderncv with some parameters. Font size 11pt, paper size A4, font sans
\documentclass[11pt, a4paper, sans]{moderncv}

% Includes all the necessary packages from packages.tex
\input{Einstellungen/packages}

% Defines commands and parameters for modifying the included packages
\input{Einstellungen/commands}

% Beginning of document
\begin{document}
    \pagestyle{empty}

    %Creates the CV title with Name and photo
    \myCVtitle[Curriculum Vitae]{ {{ personal.first_name }} }{ {{ personal.last_name }} }{Abbildungen/profile.jpg}

    %Reduce the vertical space by 10 points
    \vspace*{-10pt}

    %Personal information section
    \section{Personal Information}
        \cvline{Address}{ {{ personal.address }} \newline {% if personal.postal_code %}{{ personal.postal_code }}, {% endif %}{{ personal.city }} }
        \cvline{Phone}{ {{ personal.phone }} }
        \cvline{Email}{\href{mailto: {{ personal.email }} }{ {{ personal.email }} }}
        \cvline{Nationality}{ {{ personal.nationality }} }
        \cvline{Birthday}{ {{ personal.birthday|replace('-', '.') }} }
    {% if personal.work_permission %}
        \cvline{Work Permission}{ {{ personal.work_permission }} }
    {% endif %}

    \section{Education}
    {% for edu in education %}
        \cventry{ {{ edu.start_date|replace('-', '/') }} - {{ edu.end_date|replace('-', '/') }} }
                { {{ edu.field }} }
                { {{ edu.institution }} }
                { {{ edu.location }} }
                { {{ edu.level }} }
                {
        {% if edu.focus %}
                \begin{itemize}
            {% for item in edu.focus %}
                    \item {{ item }}
            {% endfor %}
                \end{itemize}
        {% endif %}
                }
    {% endfor %}

    \section{Work Experience}
    {% for job in experience %}

        \cventry{ {{ job.start_date|replace('-', '/') }} - {{ job.end_date|replace('-', '/') }} }
                { {{ job.title }} }
                { {{ job.company }} }
                { {{ job.location }} }
                {}
                {
        {% if job.description %}
                \begin{itemize}
            {% for desc in job.description %}
                    \item {{ desc }}
            {% endfor %}
                \end{itemize}
        {% endif %}
                }

    {% if not loop.last %}
        \vspace{6pt}
    {% endif %}
    {% endfor %}

    {% if projects %}
    \section{Notable Projects}
    {% for proj in projects %}

        \cventry{}
                { {{ proj.name }} }
                { {{ proj.role }} }
                {}
                {}
                {
        {% if proj.summary %}
                {{ proj.summary }}
        {% endif %}
        {% if proj.highlights %}
                \begin{itemize}
            {% for item in proj.highlights %}
                    \item {{ item }}
            {% endfor %}
                \end{itemize}
        {% endif %}
        {% if proj.stack %}
                \textit{Stack:} {{ proj.stack|join(', ') }}
        {% endif %}
                }

    {% endfor %}
    {% endif %}

    \section{Publications}
    {% for pub in publications|groupby('year')|reverse %}
        \cvline{ {{ pub.grouper }} }{
                \begin{itemize}
        {% for publication in pub.list %}
                    \item {{ publication.authors|join(', ') }}: \textit{``{{ publication.title }}''} {{ publication.venue }}{% if publication.url %} \url{ {{ publication.url }} }{% endif %}
            {% if publication.contribution %}
                    \begin{itemize}
                        \item \textit{Contribution:} {{ publication.contribution }}
                    \end{itemize}
            {% endif %}
        {% endfor %}
                \end{itemize}
                }
    {% endfor %}

    \section{Languages}
    {% for lang in skills.languages %}
            \cvlanguage{ {{ lang.name }} }{ {{ lang.level }} }{}
    {% endfor %}

    \section{Technical Competencies}
        \noindent\textbf{Machine Learning}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        scikit-learn, TensorFlow/Keras, PyTorch, LLM prompting, Evaluation/Model cards, Bayesian methods
        \vspace{8pt}

        \noindent\textbf{Data Engineering \& Big Data}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        ELT/ETL design, Azure Data Factory, Databricks, Spark, Delta Lake, Data contracts
        \vspace{8pt}

        \noindent\textbf{Backend}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        FastAPI/Flask, API design, Kafka, PostgreSQL, MongoDB, Neo4j, Redis, gRPC/REST, Testing (pytest), Observability
        \vspace{8pt}

        \noindent\textbf{Computer Vision \& Image Processing}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Deep learning (CNNs, transfer learning), Classical CV, Preprocessing, OpenCV, torchvision
        \vspace{8pt}

        \noindent\textbf{Cloud \& Orchestration}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Apache Airflow, Prefect, Docker/Containerization, CI/CD (Git, pipelines)
        \vspace{8pt}

        \noindent\textbf{BI \& Analytics}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Power BI (DAX, RLS), Star schema modeling, Dashboard design and governance
        \vspace{8pt}

        \noindent\textbf{Full-Stack \& Frontend}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        Django (MVC, ORM, admin), HTML/CSS/JavaScript, CRUD APIs, Templates, Godot (GDScript)
        \vspace{8pt}

        \noindent\textbf{Electrical \& Embedded Systems}
        \nopagebreak[4]
        \hspace{0pt}\rule{\linewidth}{0.2pt}
        \nopagebreak[4]
        C (embedded/programming fundamentals), Verilog (RTL design), Signal processing, Analog/digital circuits, FPGA design

    % Signature
    \sign{ {{ personal.full_name }} }{ {{ personal.city }} }{Abbildungen/profile.jpg}

\end{document}
