{
  "name": "Job Posting Detail",
  "baseSelector": "body",
  "fields": [
    {
      "name": "job_title",
      "selector": "main#content div[class*='title-styles__TitleContainer-sc-'] h1",
      "type": "text"
    },
    {
      "name": "company_name",
      "selector": "main#content div[class*='job-intro__CompanyInfo-sc-'] div[class*='job-intro__AdditionalInfos-sc-'] > a > p",
      "type": "text"
    },
    {
      "name": "location",
      "selector": "main#content div[class*='job-intro__AdditionalInfos-sc-'] div[class*='conditionals__NotOnSmall-sc-'] p:not([class*='job-intro__AdditionalInfo-sc-'])",
      "type": "text"
    },
    {
      "name": "employment_type",
      "selector": "main#content ul[class*='highlights__HighlightsWrapper-sc-'] li:nth-child(1) span[class*='aria-extended-text__Text-sc-']",
      "type": "text"
    },
    {
      "name": "salary",
      "selector": "main#content ul[class*='highlights__HighlightsWrapper-sc-'] li:nth-child(2) span[class*='marker-styles__Text-sc-']",
      "type": "text"
    },
    {
      "name": "remote_policy",
      "selector": "main#content ul[class*='highlights__HighlightsWrapper-sc-'] li:nth-child(3) span[class*='marker-styles__Text-sc-']",
      "type": "text"
    },
    {
      "name": "company_industry",
      "selector": "main#content div[class*='job-intro__AdditionalInfos-sc-'] p[class*='job-intro__AdditionalInfo-sc-']",
      "type": "text"
    },
    {
      "name": "company_size",
      "selector": "main#content div[class*='company-module-styles__CompanyModuleWrapper-sc-'] div[class*='profile-info-styles__ContentContainer-sc-'] p:nth-of-type(2)",
      "type": "text"
    }
  ]
}