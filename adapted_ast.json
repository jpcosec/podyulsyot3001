{
  "project": "Ariadne 2.0",
  "design": "plan_docs/design/ariadne-oop-architecture.md",
  "transformations": {
    "src/automation/ariadne/models.py": {
      "AriadneMap": { "target": "src/automation/ariadne/core/cognition/labyrinth.py", "class": "Labyrinth" },
      "AriadneEdge": { "target": "src/automation/ariadne/core/cognition/thread.py", "class": "AriadneThread" },
      "AriadneObserve": { "target": "src/automation/ariadne/contracts/base.py", "class": "SnapshotResult" },
      "AriadneState": { "target": "src/automation/ariadne/core/actors/state.py", "class": "AriadneState" }
    },
    "src/automation/ariadne/repository.py": {
      "MapRepository": { "target": "src/automation/ariadne/core/cognition/repository.py", "note": "Absorbed into Labyrinth/Thread loaders" }
    },
    "src/automation/ariadne/graph/orchestrator.py": {
      "observe_node": { "target": "src/automation/ariadne/core/actors/theseus.py", "class": "Theseus" },
      "execute_deterministic_node": { "target": "src/automation/ariadne/core/actors/theseus.py", "class": "Theseus" },
      "llm_rescue_agent_node": { "target": "src/automation/ariadne/core/actors/delphi.py", "class": "Delphi" },
      "human_in_the_loop_node": { "target": "src/automation/ariadne/core/actors/human.py", "class": "HumanNode" },
      "create_ariadne_graph": { "target": "src/automation/ariadne/core/graph/wiring.py", "class": "AriadneGraph" }
    },
    "src/automation/motors/": {
      "BrowserOSCliExecutor": { "target": "src/automation/ariadne/core/adapters/browseros.py", "class": "BrowserOSAdapter" },
      "Crawl4AIExecutor": { "target": "src/automation/ariadne/core/adapters/crawl4ai.py", "class": "Crawl4AIAdapter" }
    }
  }
}
